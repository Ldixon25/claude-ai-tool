    explain: 'CI/CD (Continuous Integration / Continuous Deployment) means tests run automatically on every push, and if they pass, the app deploys. This is standard at every serious company.',
    highlight: '💡 For job interviews: know the difference between a VM and a container, explain what happens when you type a URL in a browser (DNS → TCP → HTTP → render), and understand what environment variables are used for.',
    quiz: {
      q: 'What is the purpose of a .env file?',
      options: ['Store all source code', 'Store environment-specific secrets like API keys and DB URLs', 'Configure the package manager', 'Define CI/CD pipelines'],
      correct: 1,
      explanation: '.env files store secrets (API keys, database connection strings) that differ between environments. They should NEVER be committed to git — add them to .gitignore.'
    }
  },

  interview: {
    tag: 'Phase 3 · Pro Skills',
    title: 'Interview Prep',
    subtitle: 'Land the job. Know what to expect in technical interviews, what to build in your portfolio, and how to talk about code.',
    concepts: [
      { icon: '🧩', title: 'Data Structures', desc: 'Arrays, objects, linked lists, trees — know the basics and their time complexity.' },
      { icon: '🖥️', title: 'Portfolio Projects', desc: 'Build 2-3 full-stack apps with auth, CRUD, and deployment. GitHub must be active.' },
      { icon: '💬', title: 'Behavioral', desc: 'STAR method: Situation, Task, Action, Result. Prepare 5 stories.' },
      { icon: '🔍', title: 'System Design', desc: 'For senior roles: explain how to design scalable systems (caching, load balancing).' }
    ],
    codeLabel: 'JavaScript (Common Leetcode patterns)',
    code: `<span class="cmt">// Two sum — classic interview problem</span>
<span class="kw">function</span> <span class="fn">twoSum</span>(nums, target) {
  <span class="kw">const</span> map = <span class="kw">new</span> Map(); <span class="cmt">// O(1) lookup</span>

  <span class="kw">for</span> (<span class="kw">let</span> i = <span class="num">0</span>; i < nums.length; i++) {
    <span class="kw">const</span> complement = target - nums[i];

    <span class="kw">if</span> (map.<span class="fn">has</span>(complement)) {
      <span class="kw">return</span> [map.<span class="fn">get</span>(complement), i];
    }
    map.<span class="fn">set</span>(nums[i], i);
  }
}
<span class="cmt">// O(n) time, O(n) space — explain your reasoning!</span>

<span class="cmt">// FizzBuzz — still asked in 2026</span>
<span class="kw">for</span> (<span class="kw">let</span> i = <span class="num">1</span>; i <= <span class="num">100</span>; i++) {
  <span class="kw">if</span> (i % <span class="num">15</span> === <span class="num">0</span>) console.<span class="fn">log</span>(<span class="str">'FizzBuzz'</span>);
  <span class="kw">else if</span> (i % <span class="num">3</span> === <span class="num">0</span>) console.<span class="fn">log</span>(<span class="str">'Fizz'</span>);
  <span class="kw">else if</span> (i % <span class="num">5</span> === <span class="num">0</span>) console.<span class="fn">log</span>(<span class="str">'Buzz'</span>);
  <span class="kw">else</span> console.<span class="fn">log</span>(i);
}`,
    explain: 'Technical interviews test coding, system design, and cultural fit. For full-stack roles, you\'ll typically solve 1-2 coding problems and discuss a project you built. Always talk through your thinking out loud — that\'s what they\'re evaluating.',
    highlight: '💡 Portfolio checklist: 1) A full-stack app with user auth (login/register), 2) CRUD operations, 3) Deployed and live, 4) Clean GitHub repo with README. That\'s more than most candidates have.',
    quiz: {
      q: 'What time complexity is a HashMap (Map/Object) lookup in JavaScript?',
      options: ['O(n)', 'O(log n)', 'O(1)', 'O(n²)'],
      correct: 2,
      explanation: 'Hash map lookups are O(1) — constant time. This is why using a Map to store values you\'ve seen turns an O(n²) brute force into O(n) — a classic interview optimization.'
    }
  }
};

// ===================== STATE =====================
const completed = new Set();
let currentLesson = null;
const totalLessons = Object.keys(lessons).length;

// ===================== VIEWS =====================
function showView(view) {
  setActive(null);
  document.getElementById('mark-done-btn').style.display = 'none';
  document.getElementById('topbar-label').textContent = 'FULLSTACK.DEV / ' + view.toUpperCase().replace('-', ' ');

  if (view === 'welcome') renderWelcome();
  else if (view === 'roadmap') renderRoadmap();
  else if (view === 'ai-tutor') renderAiTutor();
}

function setActive(lessonKey) {
  document.querySelectorAll('.nav-item').forEach(el => {
    el.classList.remove('active');
  });
  if (lessonKey) {
    const el = document.getElementById('nav-' + lessonKey);
    if (el) el.classList.add('active');
  }
}

// ===================== WELCOME =====================
function renderWelcome() {
  const done = completed.size;
  document.getElementById('content-area').innerHTML = `
    <div class="welcome">
      <div class="welcome-eyebrow">Your path to employment</div>
      <div class="welcome-title">Become a<br><em>Full-Stack</em><br>Developer.</div>
      <div class="welcome-body">
        A structured, job-focused curriculum covering everything from your first HTML tag to deploying production APIs. 
        Each lesson teaches what employers actually test in interviews.
      </div>
      <div class="welcome-stats">
        <div class="stat">
          <div class="stat-num">${totalLessons}</div>
          <div class="stat-label">Lessons</div>
        </div>
        <div class="stat">
          <div class="stat-num">3</div>
          <div class="stat-label">Phases</div>
        </div>
        <div class="stat">
          <div class="stat-num">${done}</div>
          <div class="stat-label">Completed</div>
        </div>
      </div>
      <div class="welcome-cta">
        <button class="btn btn-primary" onclick="loadLesson('html')">Start Learning →</button>
        <button class="btn btn-ghost" onclick="showView('roadmap')">View Roadmap</button>
      </div>
      <div class="tag-row">
        <span class="tag">HTML5</span><span class="tag">CSS3</span><span class="tag">JavaScript</span>
        <span class="tag">React</span><span class="tag">Node.js</span><span class="tag">Express</span>
        <span class="tag">PostgreSQL</span><span class="tag">Git</span><span class="tag">Docker</span>
        <span class="tag">REST APIs</span><span class="tag">JWT Auth</span><span class="tag">CI/CD</span>
      </div>
    </div>
  `;
}

// ===================== ROADMAP =====================
function renderRoadmap() {
  const phases = [
    {
      name: 'Frontend Fundamentals',
      keys: ['html','css','js','dom','react'],
      labels: ['HTML & Semantics','CSS & Layouts','JavaScript Core','DOM & Events','React']
    },
    {
      name: 'Backend Development',
      keys: ['node','express','db','auth'],
      labels: ['Node.js & NPM','Express & APIs','Databases & SQL','Auth & Security']
    },
    {
      name: 'Professional Skills',
      keys: ['git','deploy','interview'],
      labels: ['Git & GitHub','Deployment','Interview Prep']
    }
  ];

  const html = phases.map((phase, i) => `
    <div class="roadmap-phase">
      <div class="phase-header">
        <div class="phase-num">${i + 1}</div>
        <div class="phase-name">${phase.name}</div>
      </div>
      <div class="phase-topics">
        ${phase.keys.map((k, j) => `
          <div class="topic-chip ${completed.has(k) ? 'done' : ''}" onclick="loadLesson('${k}')">
            ${completed.has(k) ? '✓ ' : ''}${phase.labels[j]}
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');

  document.getElementById('content-area').innerHTML = `
    <div class="roadmap">
      <div class="roadmap-title">Full-Stack Roadmap</div>
      <div class="roadmap-sub">Click any topic to jump into that lesson. Complete them in order for best results.</div>
      ${html}
    </div>
  `;
}

// ===================== LESSON =====================
function loadLesson(key) {
  currentLesson = key;
  const l = lessons[key];
  setActive(key);
  document.getElementById('mark-done-btn').style.display = completed.has(key) ? 'none' : 'block';
  document.getElementById('topbar-label').textContent = 'FULLSTACK.DEV / ' + l.title.toUpperCase();

  const keys = Object.keys(lessons);
  const idx = keys.indexOf(key);
  const prevKey = idx > 0 ? keys[idx - 1] : null;
  const nextKey = idx < keys.length - 1 ? keys[idx + 1] : null;

  document.getElementById('content-area').innerHTML = `
    <div class="lesson-area">
      <div class="lesson-tag"><span></span>${l.tag}</div>
      <div class="lesson-title">${l.title}</div>
      <div class="lesson-subtitle">${l.subtitle}</div>

      <div class="concept-grid">
        ${l.concepts.map(c => `
          <div class="concept-card">
            <div class="concept-icon">${c.icon}</div>
            <div class="concept-title">${c.title}</div>
            <div class="concept-desc">${c.desc}</div>
          </div>
        `).join('')}
      </div>

      <div class="section">
        <div class="section-title">Example Code</div>
        <div class="code-block">
          <div class="code-header">
            <span class="code-lang">${l.codeLabel}</span>
            <button class="code-copy" onclick="copyCode(this)">copy</button>
          </div>
          <pre>${l.code}</pre>
        </div>
      </div>

      <div class="section">
        <div class="section-title">Why This Matters for Jobs</div>
        <div class="section-body">${l.explain}</div>
        <div class="highlight">${l.highlight}</div>
      </div>

      <div class="quiz-box">
        <div class="quiz-title">⚡ Knowledge Check</div>
        <div class="quiz-q">${l.quiz.q}</div>
        <div class="quiz-options">
          ${l.quiz.options.map((opt, i) => `
            <button class="quiz-option" onclick="answerQuiz(this, ${i}, ${l.quiz.correct}, '${l.quiz.explanation.replace(/'/g, "\\'")}')">
              ${opt}
            </button>
          `).join('')}
        </div>
        <div class="quiz-feedback" id="quiz-fb"></div>
      </div>

      <div class="lesson-nav">
        ${prevKey ? `<button class="btn btn-ghost" onclick="loadLesson('${prevKey}')">← ${lessons[prevKey].title}</button>` : '<div></div>'}
        ${nextKey ? `<button class="btn btn-primary" onclick="loadLesson('${nextKey}')">Next: ${lessons[nextKey].title} →</button>` : '<button class="btn btn-success" onclick="showView(\'roadmap\')">🎉 View Roadmap</button>'}
      </div>
    </div>
  `;
}

function answerQuiz(btn, chosen, correct, explanation) {
  const options = btn.parentElement.querySelectorAll('.quiz-option');
  options.forEach(b => b.disabled = true);
  options[correct].classList.add('correct');
  if (chosen !== correct) btn.classList.add('wrong');

  const fb = document.getElementById('quiz-fb');
  fb.className = 'quiz-feedback show ' + (chosen === correct ? 'ok' : 'bad');
  fb.textContent = (chosen === correct ? '✓ Correct! ' : '✗ Not quite. ') + explanation;
}

function copyCode(btn) {
  const code = btn.closest('.code-block').querySelector('pre').innerText;
  navigator.clipboard.writeText(code).then(() => {
    btn.textContent = 'copied!';
    setTimeout(() => btn.textContent = 'copy', 1500);
  });
}

function markDone() {
  if (!currentLesson) return;
  completed.add(currentLesson);
  const navEl = document.getElementById('nav-' + currentLesson);
  if (navEl) navEl.classList.add('done');
  document.getElementById('mark-done-btn').style.display = 'none';
  updateProgress();
}

function updateProgress() {
  const pct = Math.round((completed.size / totalLessons) * 100);
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-pct').textContent = pct + '%';
}

// ===================== AI TUTOR =====================
function renderAiTutor() {
  document.getElementById('content-area').innerHTML = `
    <div class="ai-chat">
      <div class="ai-chat-title">AI Tutor</div>
      <div class="ai-chat-sub">Ask anything about full-stack web development. Get answers tailored to learning and landing a job.</div>
      <div class="chat-messages" id="chat-msgs">
        <div class="msg msg-ai">👋 Hey! I'm your full-stack tutor. Ask me anything — how React works, what SQL joins do, how to prepare for interviews, or anything else about web dev.</div>
      </div>
      <div class="chat-input-row">
        <input class="chat-input" id="chat-in" placeholder="Ask a question..." onkeydown="if(event.key==='Enter') sendChat()" />
        <button class="btn btn-primary" onclick="sendChat()">Send</button>
      </div>
    </div>
  `;
}

async function sendChat() {
  const input = document.getElementById('chat-in');
  const msgs = document.getElementById('chat-msgs');
  const text = input.value.trim();
  if (!text) return;

  input.value = '';

  msgs.innerHTML += `<div class="msg msg-user">${text}</div>`;
  msgs.innerHTML += `<div class="msg msg-ai loading" id="ai-loading">Thinking...</div>`;
  msgs.scrollTop = msgs.scrollHeight;

  try {
    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: 'You are an expert full-stack web development tutor helping someone prepare for their first dev job. Be concise, practical, and encouraging. Use short code examples when helpful. Focus on what employers actually care about. Keep responses under 200 words unless a longer explanation is truly needed.',
        messages: [{ role: 'user', content: text }]
      })
    });

    const data = await response.json();
    const reply = data.content[0].text;

    document.getElementById('ai-loading').remove();
    msgs.innerHTML += `<div class="msg msg-ai">${reply.replace(/\n/g, '<br>')}</div>`;
  } catch (err) {
    document.getElementById('ai-loading').remove();
    msgs.innerHTML += `<div class="msg msg-ai">Sorry, couldn't connect to the AI. Make sure you're running this on claude.ai or a platform with API access.</div>`;
  }

  msgs.scrollTop = msgs.scrollHeight;
}

// ===================== INIT =====================
renderWelcome();
</script>
</body>
</html>
